APP_ENV=development
APP_NAME=OmniSync Emlak
APP_URL=https://emlak.omnisync.life
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRE_MIN=30
JWT_REFRESH_EXPIRE_DAYS=30

POSTGRES_DB=omnisync
POSTGRES_USER=omnisync
POSTGRES_PASSWORD=omnisync
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://omnisync:omnisync@postgres:5432/omnisync

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=omnisync_verify_token
META_GRAPH_VERSION=v20.0
META_WEBHOOK_PATH=/api/v1/webhooks/meta
META_OAUTH_REDIRECT_URI=https://emlak.omnisync.life/api/v1/instagram/oauth/callback

OPENAI_API_KEY=
OPENAI_MODEL_INTENT=gpt-4.1-mini
OPENAI_MODEL_REPLY=gpt-4.1-mini
OPENAI_MODEL_EXTRACTION=gpt-4.1-mini

# AI Provider (openai or gemini)
AI_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
MANUAL_APPROVAL_DEFAULT=true
DAILY_MAX_REPLY_PER_ACCOUNT=250
REPLY_DELAY_MIN_SEC=30
REPLY_DELAY_MAX_SEC=120

POLLING_ENABLED=true
POLLING_INTERVAL_SEC=180
POLLING_MEDIA_LIMIT=10
POLLING_COMMENTS_LIMIT=50

ADMIN_EMAIL=owner@omnisync.life
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=OmniSync Owner
COMPANY_NAME=OmniSync

SLACK_WEBHOOK_URL=
ALERT_CHECK_INTERVAL_SEC=60

LOG_LEVEL=INFO
